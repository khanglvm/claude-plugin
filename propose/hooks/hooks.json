{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": {
        "toolName": "Write",
        "pattern": "OPEN-QUESTIONS.md"
      },
      "command": "bash \"$HOME/.claude/plugins/propose/scripts/validate-open-questions.sh\" \"$TOOL_INPUT_FILE_PATH\" 2>&1 || true",
      "description": "Validates OPEN-QUESTIONS.md entries have proposed solutions and /propose commands"
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "toolName": "Write",
        "pattern": "conflict-report.md"
      },
      "command": "bash \"$HOME/.claude/plugins/propose/scripts/validate-conflict-report.sh\" \"$TOOL_INPUT_FILE_PATH\" 2>&1 || true",
      "description": "Validates all conflict-report items are RESOLVED with ADR references"
    }
  ]
}
